# REPORTING TASKS
# ─────────────────────────────────────────────

@celery_app.task
def generate_nps_report(survey_id: int) -> dict:
    """Calculate NPS, CSAT, completion rate for a survey."""
    import asyncio

    async def _calc():
        from app.db.session import AsyncSessionLocal
        from sqlalchemy import select, func
        from app.models.models import SurveyResponse

        async with AsyncSessionLocal() as db:
            result = await db.execute(
                select(SurveyResponse).where(
                    SurveyResponse.survey_id == survey_id,
                    SurveyResponse.is_complete == True,
                )
            )
            responses = result.scalars().all()

            if not responses:
                return {"survey_id": survey_id, "total_responses": 0, "nps_score": None}

            nps_scores = [r.nps_score for r in responses if r.nps_score is not None]
            promoters  = sum(1 for s in nps_scores if s >= 9)
            passives   = sum(1 for s in nps_scores if 7 <= s <= 8)
            detractors = sum(1 for s in nps_scores if s <= 6)
            total_nps  = len(nps_scores)

            nps = round(((promoters - detractors) / total_nps) * 100, 1) if total_nps else 0

            csat_scores = [r.csat_score for r in responses if r.csat_score is not None]
            avg_csat = round(sum(csat_scores) / len(csat_scores), 2) if csat_scores else None

            return {
                "survey_id": survey_id,
                "total_responses": len(responses),
                "promoters": promoters,
                "passives": passives,
                "detractors": detractors,
                "nps_score": nps,
                "avg_csat": avg_csat,
            }

    return asyncio.get_event_loop().run_until_complete(_calc())


@celery_app.task
def export_to_excel(survey_id: int, output_path: str):
    """Export survey responses to Excel with per-question sheets."""
    import asyncio
    import pandas as pd

    async def _export():
        from app.db.session import AsyncSessionLocal
        from sqlalchemy import select
        from app.models.models import SurveyResponse, Answer, Question

        async with AsyncSessionLocal() as db:
            resp_result = await db.execute(
                select(SurveyResponse).where(SurveyResponse.survey_id == survey_id)
            )
            responses = resp_result.scalars().all()

            rows = []
            for r in responses:
                ans_result = await db.execute(select(Answer).where(Answer.response_id == r.id))
                answers = ans_result.scalars().all()
                row = {
                    "response_id": r.id,
                    "submitted_at": r.submitted_at,
                    "is_complete": r.is_complete,
                    "nps_score": r.nps_score,
                    "csat_score": r.csat_score,
                }
                for a in answers:
                    row[f"q_{a.question_id}"] = a.value_text or a.value_numeric or str(a.value_choices or "")
                rows.append(row)

            df = pd.DataFrame(rows)
            with pd.ExcelWriter(output_path, engine="openpyxl") as writer:
                df.to_excel(writer, sheet_name="Responses", index=False)

            logger.info(f"Excel exported: {output_path}")
            return output_path

    return asyncio.get_event_loop().run_until_complete(_export())


@celery_app.task
def export_to_pptx(survey_id: int, output_path: str):
    """Generate a PowerPoint summary report from NPS data."""
    from pptx import Presentation
    from pptx.util import Inches, Pt
    from pptx.dml.color import RGBColor

    nps_data = generate_nps_report(survey_id)

    prs = Presentation()
    slide_layout = prs.slide_layouts[5]

    # Title slide
    slide = prs.slides.add_slide(prs.slide_layouts[0])
    slide.shapes.title.text = "Survey Report"
    slide.placeholders[1].text = f"Survey ID: {survey_id}"

    # NPS Summary slide
    slide2 = prs.slides.add_slide(slide_layout)
    tf = slide2.shapes.add_textbox(Inches(1), Inches(1), Inches(8), Inches(5))
    frame = tf.text_frame
    frame.word_wrap = True

    p = frame.add_paragraph()
    p.text = f"NPS Score: {nps_data.get('nps_score', 'N/A')}"
    p.font.size = Pt(32)
    p.font.bold = True

    for key in ("total_responses", "promoters", "passives", "detractors", "avg_csat"):
        p2 = frame.add_paragraph()
        p2.text = f"{key.replace('_', ' ').title()}: {nps_data.get(key, 'N/A')}"
        p2.font.size = Pt(18)

    prs.save(output_path)
    logger.info(f"PPTX exported: {output_path}")
    return output_path
